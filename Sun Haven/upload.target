<Project xmlns="http://schemas.microsoft.com/developer/msbuild/2003">

  <!--
    NexusMods Upload Target
    Usage: dotnet build ProjectName.csproj -c Release-Upload
    Requires: NexusGroupId in csproj, NexusModsApiKey in Environment.props
  -->

  <Target Name="NexusUpload" AfterTargets="ZipOutputPath" Condition="'$(Configuration)'=='Release-Upload' AND '$(NexusGroupId)' != '' AND '$(NexusModsApiKey)' != ''">

    <PropertyGroup>
      <ReleasesDir>$(MSBuildProjectDirectory)\..\AAA_Releases</ReleasesDir>
      <ZipFile>$(ReleasesDir)\$(MSBuildProjectName)_v$(Version)_BepInEx.zip</ZipFile>
      <UploadScript>$(MSBuildProjectDirectory)\..\nexus-upload.ps1</UploadScript>
      <ChangelogFile>$(MSBuildProjectDirectory)\CHANGELOG.md</ChangelogFile>
    </PropertyGroup>

    <Error Condition="!Exists('$(ZipFile)')" Text="Release zip not found: $(ZipFile)" />
    <Error Condition="!Exists('$(UploadScript)')" Text="Upload script not found: $(UploadScript)" />

    <Exec Command="pwsh -NoProfile -ExecutionPolicy Bypass -File &quot;$(UploadScript)&quot; -ApiKey &quot;$(NexusModsApiKey)&quot; -GroupId &quot;$(NexusGroupId)&quot; -ZipFile &quot;$(ZipFile)&quot; -ModName &quot;$(MSBuildProjectName)&quot; -Version &quot;$(Version)&quot; -ChangelogFile &quot;$(ChangelogFile)&quot;" />

  </Target>

  <Target Name="NexusUploadCheck" BeforeTargets="Build" Condition="'$(Configuration)'=='Release-Upload'">
    <Warning Condition="'$(NexusGroupId)' == ''" Text="NexusGroupId not set — upload skipped for $(MSBuildProjectName)." />
    <Warning Condition="'$(NexusModsApiKey)' == ''" Text="NexusModsApiKey not set — upload skipped." />
  </Target>

</Project>
