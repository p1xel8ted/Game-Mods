<Project>
    <!--
        Auto-populate <Version> from the first "## X.Y.Z" header in CHANGELOG.md.
        Runs AFTER each csproj's own <Version>, so the changelog is the source of
        truth and csproj-level Version becomes a fallback when the file is missing
        or contains no matching header. Feeds MyPluginInfo.PLUGIN_VERSION, the
        [BepInPlugin] attribute, and the zip filename without any hand-sync.
    -->
    <PropertyGroup Condition="Exists('$(MSBuildProjectDirectory)\CHANGELOG.md')">
        <_ChangelogFileContents>$([System.IO.File]::ReadAllText('$(MSBuildProjectDirectory)\CHANGELOG.md'))</_ChangelogFileContents>
        <_VersionFromChangelog>$([System.Text.RegularExpressions.Regex]::Match($(_ChangelogFileContents), '##\s+(\d+\.\d+\.\d+)').Groups[1].Value)</_VersionFromChangelog>
        <Version Condition="'$(_VersionFromChangelog)' != ''">$(_VersionFromChangelog)</Version>
    </PropertyGroup>

    <Import Project="zip.target" Condition="('$(Configuration)' == 'Release' Or '$(Configuration)' == 'Release-Upload') And Exists('$(MSBuildThisFileDirectory)zip.target')" />
</Project>
